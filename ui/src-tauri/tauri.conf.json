{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "geenii-desktop",
  "version": "0.2.0",
  "identifier": "io.geenii.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "geenii",
        "width": 1024,
        "height": 768,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' site: asset: http://site.localhost http://localhost:13030 http://127.0.0.1:13030",
        "frame-src": "'self' site: http://site.localhost",
        "child-src": "'self' site: http://site.localhost"
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "app",
      "dmg",
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "frameworks": [
        "/System/Library/Frameworks/CoreAudio.framework"
      ]
    },
    "externalBin": [
      "binaries/geeniid"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://updates.geenii.app/latest.json",
        "https://updates.geenii.app/updater.php?target={{target}}&arch={{arch}}&current_version={{current_version}}",
        "https://geenii.flowmotion-labs.com/updates.latest.json",
        "https://geenii.flowmotion-labs.com/updater.php?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1RjE5RkVBRTEwNkVFMDYKUldRRzdnYmg2cC94UmRNMVg2M2tpT0FzUDFUWlF4WWFkZE0rMU1OY3FDV1VVL1d1d2FUOTVrRTkK"
    }
  }
}